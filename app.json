{
  "name": "LockIN",
  "description": "LockIN study tool with OCR-backed document import",
  "keywords": ["node", "express", "react", "ocr", "heroku"],
  "buildpacks": [
    {
      "url": "https://github.com/heroku/heroku-buildpack-apt"
    },
    {
      "url": "https://github.com/heroku/heroku-buildpack-python"
    },
    {
      "url": "https://github.com/heroku/heroku-buildpack-nodejs"
    }
  ],
  "env": {
    "TESSDATA_PREFIX": {
      "description": "Path to Tesseract language data for OCR",
      "value": "/app/.apt/usr/share/tesseract-ocr/5/tessdata",
      "required": false
    }
  }
}